{
    "name": "ralfhortt/wp-post-meta",
    "description": "WordPress post meta utilities for admin list tables",
    "license": "MIT",
    "authors": [
        {
            "name": "Ralf Hortt",
            "email": "mail@ralfhortt.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "RalfHortt\\Meta\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RalfHortt\\Meta\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "mockery/mockery": "^1.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "@php -r \"if(!extension_loaded('xdebug') && !extension_loaded('pcov')) { echo 'Code coverage requires Xdebug or PCOV extension' . PHP_EOL; exit(1); }\" && pest --coverage",
        "test:watch": "pest --watch",
        "test:parallel": "pest --parallel"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
